# ──────────────────────────────────────────────────────────────
# Sentinel — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────
# Which inference backend to use: ollama | gemini | openai
LLM_PROVIDER=ollama

# ── Ollama (primary / default) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Default model used for all stages unless a per-stage override is set.
OLLAMA_MODEL=qwen3.6:35b-a3b-nvfp4

# Per-stage model overrides (leave empty to use OLLAMA_MODEL).
OLLAMA_MODEL_CLASSIFY=
OLLAMA_MODEL_SENTIMENT=
OLLAMA_MODEL_RELEVANCE=
OLLAMA_MODEL_RISK=
OLLAMA_MODEL_THEMES=
# Executive summary benefits from a larger, more fluent model.
OLLAMA_MODEL_SUMMARY=gemma4:latest

# HTTP request timeout in seconds (large models can be slow).
OLLAMA_TIMEOUT=300

# Context window size (tokens). 32K is recommended for 64GB+ machines.
OLLAMA_NUM_CTX=32768

# Max output tokens. 8192 ensures long JSON outputs (themes, summaries) aren't truncated.
OLLAMA_NUM_PREDICT=8192

# HuggingFace token for embedding model downloads (avoids 403 errors).
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ── Gemini (optional) ─────────────────────────────────────────
# Required only when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenAI (optional) ─────────────────────────────────────────
# Required only when LLM_PROVIDER=openai
# Also compatible with OpenAI-API-compatible services (LM Studio, vLLM, etc.)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Override to use a custom-compatible endpoint:
# OPENAI_BASE_URL=http://localhost:1234/v1

# ── Application ───────────────────────────────────────────────
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ── Database (future) ─────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/sentinel
